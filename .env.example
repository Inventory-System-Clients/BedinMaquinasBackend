# Server
PORT=3001
NODE_ENV=development

# Database PostgreSQL
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Admin padrão
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Machine Pay (painel Cyberpix - leitores PIX/cartão das máquinas)
MACHINE_PAY_LOGIN_URL=https://www.cyberpix.com.br/pix-adesivo-clientes/
MACHINE_PAY_LOGIN=
MACHINE_PAY_PASSWORD=
MACHINE_PAY_API_TEMPLATE=https://www.cyberpix.com.br/pix-adesivo-clientes/maquinas.php?acao=stats&posid={posid}&dataini={inicio64}&datafim={fim64}&chave={chave}
MACHINE_PAY_CHAVE=

# Opcionais (têm defaults hardcoded no service, só sobrescreva se necessário):
# MACHINE_PAY_FECHAMENTO_TEMPLATE=
# MACHINE_PAY_MQTT_TEMPLATE=
# MACHINE_PAY_MQTT_METHOD=POST
# MACHINE_PAY_MQTT_ACAO=creditar
# MACHINE_PAY_MQTT_ORIGEM=1
# MACHINE_PAY_MQTT_TPAGTO=Manual
# MACHINE_PAY_MQTT_BANCO=Pagto manual criado
# MACHINE_PAY_WS_DOMINIO=cyberpix.com.br
# MACHINE_PAY_WS_TOKEN=1
# MACHINE_PAY_WS_USUARIO=1
# MACHINE_PAY_USR=
